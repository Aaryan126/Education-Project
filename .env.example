# Core model providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ZAI_API_KEY=
ZAI_BASE_URL=

# Provider/model selection
LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
ZAI_MODEL=glm-4.6
OPENAI_VISION_MODEL=gpt-4o
OPENAI_STT_MODEL=gpt-4o-transcribe
TTS_PROVIDER=browser
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=onyx
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_TTS_VOICE=en-US-Chirp-HD-O
GOOGLE_TTS_API_ENDPOINT=
GOOGLE_TTS_MONTHLY_FREE_CHARACTERS=1000000
# Use either GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# or paste the JSON into GOOGLE_TTS_CREDENTIALS_JSON for hosted deployments.
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_PROJECT_ID=

# Supabase persistence
# Keep SUPABASE_SECRET_KEY / SUPABASE_SERVICE_ROLE_KEY server-side only.
SUPABASE_URL=https://ejbpzofzatkgkjngvnch.supabase.co
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=materials
SUPABASE_OWNER_KEY=main

# App behavior
DEFAULT_TUTOR_LANGUAGE=zh-CN
DEFAULT_SOURCE_LANGUAGE=auto
DEFAULT_TTS_VOICE=en-US-GuyNeural

# Runtime
APP_ENV=development
APP_PORT=3000
