      "versionNonce": 500404,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "text": "The voice tutor is a gated learning loop: speech is segmented into a completed turn, transcribed, enriched with voice signals,\noptionally evaluated as retrieval evidence, routed through a Socratic LLM, spoken back, then converted into the next progress check.",
      "originalText": "The voice tutor is a gated learning loop: speech is segmented into a completed turn, transcribed, enriched with voice signals,\noptionally evaluated as retrieval evidence, routed through a Socratic LLM, spoken back, then converted into the next progress check.",
